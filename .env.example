APP_ENV=development

# Backend
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Frontend
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8080/api/v1

# PostgreSQL
POSTGRES_USER=umkm_user
POSTGRES_PASSWORD=umkm_password
POSTGRES_DB=umkm_tumbuh
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://umkm_user:umkm_password@localhost:5432/umkm_tumbuh?sslmode=disable

# JWT
JWT_SECRET=change-me
JWT_EXPIRE_MINUTES=1440

# Garage / S3-compatible object storage
OBJECT_STORAGE_ENDPOINT=http://garage:3900
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://localhost:3900
OBJECT_STORAGE_REGION=garage
OBJECT_STORAGE_USE_SSL=false

OBJECT_STORAGE_ACCESS_KEY=umkm_garage_access_key
OBJECT_STORAGE_SECRET_KEY=umkm_garage_secret_key

OBJECT_STORAGE_BUCKET_DOCUMENTS=documents
OBJECT_STORAGE_BUCKET_CERTIFICATES=certificates
OBJECT_STORAGE_BUCKET_PRODUCT_IMAGES=product-images
OBJECT_STORAGE_BUCKET_PARTNERSHIP_FILES=partnership-files

GARAGE_ADMIN_TOKEN=CHANGE_ME_LOCAL_GARAGE_ADMIN_TOKEN

# SMTP later
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=


# Default local admin seed
ADMIN_ID=AKUNADMIN001
ADMIN_FULL_NAME=Admin Pemerintah
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# User Service
USER_SERVICE_HOST=0.0.0.0
USER_SERVICE_PORT=8081


# Partnership Service
PARTNERSHIP_SERVICE_HOST=0.0.0.0
PARTNERSHIP_SERVICE_PORT=8082


# Document Service
DOCUMENT_SERVICE_HOST=0.0.0.0
DOCUMENT_SERVICE_PORT=8083
