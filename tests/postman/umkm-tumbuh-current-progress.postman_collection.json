        "exec": [
          "if (!pm.environment.get('run_id')) {",
          "  const suffix = String(Date.now()).slice(-10);",
          "  pm.environment.set('run_id', suffix);",
          "  pm.environment.set('umkm_test_email', `newman.umkm.${suffix}@example.com`);",
          "  pm.environment.set('umkm_test_phone', `08${suffix}`);",
          "  pm.environment.set('umkm_test_nik', (`3372${suffix}000000000000`).slice(0, 16));",
          "}",
          ""
        ]
      }
    }
