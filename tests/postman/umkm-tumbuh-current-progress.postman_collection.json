            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Newman UMKM Owner {{run_id}}\",\n  \"email\": \"{{umkm_test_email}}\",\n  \"phone_number\": \"{{umkm_test_phone}}\",\n  \"nik\": \"{{umkm_test_nik}}\",\n  \"password\": \"{{umkm_test_password}}\",\n  \"role\": \"UMKM\"\n}",
              "options": {
                "raw": {
                  "language": "json"
