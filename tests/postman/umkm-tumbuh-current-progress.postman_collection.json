    {
      "name": "01 - Auth + Admin Approval Flow",
      "item": [
        {
          "name": "HP-AUTH-001 Admin login seeded account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{auth_base_url}}/api/v1/auth/login",
              "host": [
                "{{auth_base_url}}/api/v1/auth/login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin login returns 200', () => pm.response.to.have.status(200));",
                  "pm.response.to.be.json;",
                  "const json = pm.response.json();",
                  "pm.expect(json.access_token, 'access_token').to.be.a('string').and.not.empty;",
                  "pm.environment.set('admin_access_token', json.access_token);",
                  "pm.test('Admin role returned', () => pm.expect(json.user.role).to.eql('ADMIN'));"
                ]
              }
            }
          ]
        },
        {
          "name": "HP-AUTH-002 Register UMKM account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{auth_base_url}}/api/v1/auth/register",
              "host": [
                "{{auth_base_url}}/api/v1/auth/register"
