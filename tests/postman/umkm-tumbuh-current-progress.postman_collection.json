          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register returns 201 Created', () => pm.response.to.have.status(201));",
                  "pm.response.to.be.json;",
                  "const json = pm.response.json();",
                  "pm.expect(json.user.id, 'user.id').to.be.a('string').and.not.empty;",
                  "pm.environment.set('umkm_account_id', json.user.id);",
                  "pm.test('New account starts as MENUNGGU', () => pm.expect(json.user.status).to.eql('MENUNGGU'));"
