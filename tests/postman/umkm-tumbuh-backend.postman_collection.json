            "pm.environment.set('mitra_token', json.access_token);"
          ] } }]
        },
        {
          "name": "SP-ADMIN-001 Non-admin cannot approve",
          "request": {
            "method": "PATCH",
            "header": [{"key":"Authorization","value":"Bearer {{umkm_token}}"}],
            "url": { "raw": "{{auth_base_url}}/api/v1/admin/registrations/{{umkm_user_id}}/approve", "host": ["{{auth_base_url}}"], "path": ["api","v1","admin","registrations","{{umkm_user_id}}","approve"] }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 403', () => pm.response.to.have.status(403));"] } }]
        }
