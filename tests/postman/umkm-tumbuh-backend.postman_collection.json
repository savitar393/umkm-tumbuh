        {
          "name": "HP-AUTH-001 Admin login successfully",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{auth_base_url}}/api/v1/auth/login",
              "host": [
                "{{auth_base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Happy Path: seeded admin can login.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Admin token exists', function () { pm.expect(json.access_token).to.be.a('string').and.not.empty; });",
                  "pm.test('Admin role is ADMIN', function () { pm.expect(json.user.role).to.eql('ADMIN'); });",
                  "pm.environment.set('admin_token', json.access_token);"
                ]
              }
            }
          ]
