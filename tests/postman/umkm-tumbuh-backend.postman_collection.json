{
  "info": {
    "_postman_id": "041c949c-cfb0-429b-a81b-c6455ba71977",
    "name": "UMKM Tumbuh Backend - Happy Alternative Sad Path",
    "description": "Newman automated backend tests: happy path, alternative path, and sad path.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('run_id')) {",
          "  const runId = Date.now().toString();",
          "  pm.environment.set('run_id', runId);",
          "  pm.environment.set('umkm_email', `qa.umkm.${runId}@example.com`);",
          "  pm.environment.set('mitra_email', `qa.mitra.${runId}@example.com`);",
          "  pm.environment.set('umkm_password', 'password12345');",
          "  pm.environment.set('mitra_password', 'password12345');",
          "  pm.environment.set('umkm_phone', `08${runId.slice(-11)}`);",
          "  pm.environment.set('mitra_phone', `09${runId.slice(-11)}`);",
          "  pm.environment.set('umkm_nik', `3372${runId.slice(-12).padStart(12, '0')}`);",
          "  pm.environment.set('mitra_nik', `3373${runId.slice(-12).padStart(12, '0')}`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 - Health Checks",
      "item": [
        {
          "name": "HP-HEALTH-001 Auth service health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{auth_base_url}}/api/v1/health", "host": ["{{auth_base_url}}"], "path": ["api","v1","health"] }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "HP-HEALTH-002 Auth DB health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{auth_base_url}}/api/v1/health/db", "host": ["{{auth_base_url}}"], "path": ["api","v1","health","db"] }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "HP-HEALTH-003 User service health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{user_base_url}}/api/v1/health", "host": ["{{user_base_url}}"], "path": ["api","v1","health"] }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "HP-HEALTH-004 User DB health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{user_base_url}}/api/v1/health/db", "host": ["{{user_base_url}}"], "path": ["api","v1","health","db"] }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }]
        }
      ]
    },
    {
      "name": "01 - Auth Registration Flow",
      "item": [
        {
          "name": "HP-AUTH-001 Admin login",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "{{auth_base_url}}/api/v1/auth/login", "host": ["{{auth_base_url}}"], "path": ["api","v1","auth","login"] },
            "body": { "mode": "raw", "raw": "{\"email\":\"{{admin_email}}\",\"password\":\"{{admin_password}}\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Token exists', () => pm.expect(json.access_token).to.be.a('string').and.not.empty);",
            "pm.environment.set('admin_token', json.access_token);"
          ] } }]
        },
        {
          "name": "HP-REG-001 Register UMKM",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "{{auth_base_url}}/api/v1/auth/register", "host": ["{{auth_base_url}}"], "path": ["api","v1","auth","register"] },
            "body": { "mode": "raw", "raw": "{\"full_name\":\"QA UMKM {{run_id}}\",\"email\":\"{{umkm_email}}\",\"phone_number\":\"{{umkm_phone}}\",\"nik\":\"{{umkm_nik}}\",\"password\":\"{{umkm_password}}\",\"role\":\"UMKM\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.test('Role is UMKM', () => pm.expect(json.user.role).to.eql('UMKM'));",
            "pm.environment.set('umkm_user_id', json.user.id);"
          ] } }]
        },
        {
          "name": "AP-REG-001 Register Mitra",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "{{auth_base_url}}/api/v1/auth/register", "host": ["{{auth_base_url}}"], "path": ["api","v1","auth","register"] },
            "body": { "mode": "raw", "raw": "{\"full_name\":\"QA Mitra {{run_id}}\",\"email\":\"{{mitra_email}}\",\"phone_number\":\"{{mitra_phone}}\",\"nik\":\"{{mitra_nik}}\",\"password\":\"{{mitra_password}}\",\"role\":\"MITRA\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.environment.set('mitra_user_id', json.user.id);"
          ] } }]
        },
        {
          "name": "SP-REG-001 Duplicate email",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "{{auth_base_url}}/api/v1/auth/register", "host": ["{{auth_base_url}}"], "path": ["api","v1","auth","register"] },
            "body": { "mode": "raw", "raw": "{\"full_name\":\"Duplicate User\",\"email\":\"{{umkm_email}}\",\"phone_number\":\"{{umkm_phone}}\",\"nik\":\"{{umkm_nik}}\",\"password\":\"{{umkm_password}}\",\"role\":\"UMKM\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));"
          ] } }]
        },
        {
          "name": "SP-REG-002 Invalid email",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "{{auth_base_url}}/api/v1/auth/register", "host": ["{{auth_base_url}}"], "path": ["api","v1","auth","register"] },
            "body": { "mode": "raw", "raw": "{\"full_name\":\"Bad Email\",\"email\":\"not-an-email\",\"phone_number\":\"081111111111\",\"nik\":\"3372000000000000\",\"password\":\"password12345\",\"role\":\"UMKM\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"] } }]
        },
        {
          "name": "SP-REG-003 Invalid role (ADMIN)",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "{{auth_base_url}}/api/v1/auth/register", "host": ["{{auth_base_url}}"], "path": ["api","v1","auth","register"] },
            "body": { "mode": "raw", "raw": "{\"full_name\":\"Bad Role\",\"email\":\"bad.role@example.com\",\"phone_number\":\"081111111112\",\"nik\":\"3372000000000001\",\"password\":\"password12345\",\"role\":\"ADMIN\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"] } }]
        }
      ]
