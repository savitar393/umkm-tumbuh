          ] } }]
        },
        {
          "name": "HP-PROFILE-002 Update UMKM profile",
          "request": {
            "method": "PUT",
            "header": [
              {"key":"Authorization","value":"Bearer {{umkm_token}}"},
              {"key":"Content-Type","value":"application/json"}
            ],
            "url": { "raw": "{{user_base_url}}/api/v1/profiles/me", "host": ["{{user_base_url}}"], "path": ["api","v1","profiles","me"] },
            "body": { "mode": "raw", "raw": "{\"business_name\":\"QA UMKM Usaha\",\"business_category\":\"Kuliner\",\"owner_name\":\"QA UMKM Owner\",\"nik\":\"{{umkm_nik}}\",\"phone_number\":\"081234567890\",\"address\":\"Jl. Contoh No. 1\",\"city\":\"Semarang\",\"province\":\"Jawa Tengah\"}" }
